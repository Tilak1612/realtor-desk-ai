.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock
.claude/settings.local.json
