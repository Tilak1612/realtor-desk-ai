{
  "// INFO": "Claude Code settings for RealtorDesk AI — realtor-desk-ai repo",

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(bun run lint)",
      "Bash(bun run typecheck)",
      "Bash(bun run test)",
      "Bash(bun run build)",
      "Bash(npx supabase gen types typescript*)",
      "Bash(npx supabase db diff*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(npx i18next*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git merge*)",
      "Bash(rm -rf*)",
      "Bash(supabase db push*)",
      "Bash(npx supabase db reset*)",
      "Bash(vercel --prod*)",
      "Bash(stripe*)"
    ]
  },

  "context": {
    "files": [
      "CLAUDE.md",
      "SKILL.md",
      "docs/brand-context-pack.md"
    ]
  },

  "model": {
    "default": "claude-sonnet-4-6",
    "// options": "claude-sonnet-4-6 | claude-opus-4-6"
  },

  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "{GITHUB_TOKEN}"
      }
    }
  }
}
